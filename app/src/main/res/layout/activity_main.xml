<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/brand_name"
                android:textColor="@color/text_main"
                android:textSize="28sp"
                android:textStyle="bold" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/about"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="10dp"
                        android:textStyle="bold"
                        android:textColor="@color/text_main"
                        android:background="@drawable/rounded_chip"
                        android:layout_marginEnd="10dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/skills"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="10dp"
                        android:textStyle="bold"
                        android:textColor="@color/text_main"
                        android:layout_marginEnd="10dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/projects"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="10dp"
                        android:textStyle="bold"
                        android:textColor="@color/text_main"
                        android:layout_marginEnd="10dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/contact"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="10dp"
                        android:textStyle="bold"
                        android:textColor="@color/text_main"/>
                </LinearLayout>
            </HorizontalScrollView>

            <Button
                android:id="@+id/btnContactTop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/contact_me"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:backgroundTint="@color/primary"
                android:layout_marginTop="14dp" />
        </LinearLayout>

        <!-- About badge -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/about"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="16sp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:background="@drawable/rounded_badge"
            android:layout_marginBottom="16dp"/>

        <!-- Profile card -->

        <!-- About content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="18dp"
            android:background="@drawable/rounded_card"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="20dp">

            <ImageView
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_marginBottom="18dp"
                android:scaleType="centerCrop"
                android:src="@drawable/avatar" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="43dp"
                android:layout_marginBottom="8dp"
                android:text="Nhu Ngoc"
                android:textColor="@color/text_main"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="center"
                android:letterSpacing="0.15"
                android:text="BUSINESS ANALYSIS • 3RD YEAR STUDENT"
                android:textColor="@color/text_muted"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email · Phone"
                android:textColor="@color/pink_soft"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_card"
            android:padding="20dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hello_title"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/text_main"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• Motivated and fast-learning student majoring in Information Systems, transitioning into Business Analysis."
                android:textSize="18sp"
                android:textColor="@color/text_main"
                android:lineSpacingExtra="6dp"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• Enjoy turning data into insights and building smooth processes between users and engineering."
                android:textSize="18sp"
                android:textColor="@color/text_main"
                android:lineSpacingExtra="6dp"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• Recently achieved a GPA 3.9/4.0 and a Merit Scholarship."
                android:textSize="18sp"
                android:textColor="@color/text_main"
                android:lineSpacingExtra="6dp"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• Eager to contribute to digital transformation projects—from requirements discovery and documentation to evaluating solutions with measurable impact."
                android:textSize="18sp"
                android:textColor="@color/text_main"
                android:lineSpacingExtra="6dp"/>
        </LinearLayout>

        <!-- Skills -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/skills"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="16sp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:background="@drawable/rounded_badge"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/work_with"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/text_main"
            android:layout_marginBottom="18dp"/>

        <!-- Skill card 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_card"
            android:padding="18dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Data Analysis"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/text_main"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="★★★★☆"
                android:textColor="@color/star"
                android:textSize="22sp"
                android:layout_marginBottom="12dp"/>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Excel"
                        android:background="@drawable/rounded_chip"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="8dp"
                        android:textStyle="bold"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Power BI"
                        android:background="@drawable/rounded_chip"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="8dp"
                        android:textStyle="bold"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Google Sheets"
                        android:background="@drawable/rounded_chip"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="8dp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>

        <!-- Skill card 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_card"
            android:padding="18dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Programming"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/text_main"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="★★★☆☆"
                android:textColor="@color/star"
                android:textSize="22sp"
                android:layout_marginBottom="12dp"/>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Python"
                        android:background="@drawable/rounded_chip"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="8dp"
                        android:textStyle="bold"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SQL"
                        android:background="@drawable/rounded_chip"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="8dp"
                        android:textStyle="bold"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Java"
                        android:background="@drawable/rounded_chip"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="8dp"
                        android:textStyle="bold"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="C++"
                        android:background="@drawable/rounded_chip"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="8dp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>

        <!-- Projects -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/projects"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="16sp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:background="@drawable/rounded_badge"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/built_title"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="@color/text_main"
            android:layout_marginBottom="18dp"/>

        <!-- Project 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_card"
            android:layout_marginBottom="18dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:src="@drawable/project1"
                android:scaleType="centerCrop"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TryOnMe – Project Management"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_main"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Student project · Project management, report with good structure."
                    android:textSize="17sp"
                    android:textColor="@color/text_muted"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="12dp"/>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Power BI"
                            android:background="@drawable/rounded_chip"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="8dp"
                            android:textStyle="bold"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Excel"
                            android:background="@drawable/rounded_chip"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="8dp"
                            android:textStyle="bold"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Data Viz"
                            android:background="@drawable/rounded_chip"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="8dp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </HorizontalScrollView>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp">

                    <Button
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Live Demo"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:backgroundTint="@color/primary"
                        android:layout_marginEnd="10dp"/>

                    <Button
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Case Notes"
                        android:textAllCaps="false"
                        android:textColor="@color/primary"
                        android:textStyle="bold"
                        android:backgroundTint="@color/white"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Contact -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/contact"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="16sp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:background="@drawable/rounded_badge"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/work_together"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="@color/text_main"
            android:layout_marginBottom="18dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_card"
            android:padding="20dp"
            android:layout_marginBottom="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Name"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_main"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/edtName"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:hint="Your name"
                android:background="@drawable/rounded_input"
                android:paddingHorizontal="16dp"
                android:textColor="@color/text_main"
                android:layout_marginBottom="14dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_main"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/edtEmail"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:hint="you@example.com"
                android:inputType="textEmailAddress"
                android:background="@drawable/rounded_input"
                android:paddingHorizontal="16dp"
                android:textColor="@color/text_main"
                android:layout_marginBottom="14dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Message"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_main"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/edtMessage"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:hint="Tell me about your project..."
                android:gravity="top"
                android:background="@drawable/rounded_input"
                android:padding="16dp"
                android:textColor="@color/text_main"
                android:layout_marginBottom="16dp"/>

            <Button
                android:id="@+id/btnSend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Send"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:backgroundTint="@color/primary"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_card"
            android:padding="20dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Contact details"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/text_main"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email: nhungoc230805@gmail.com"
                android:textSize="18sp"
                android:textColor="@color/text_main"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phone: 0903230805"
                android:textSize="18sp"
                android:textColor="@color/text_main"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Location: Ho Chi Minh City, Vietnam"
                android:textSize="18sp"
                android:textColor="@color/text_main"
                android:layout_marginBottom="14dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="I usually reply within 24h."
                android:textSize="17sp"
                android:textColor="@color/text_muted"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="© 2026 Nguyen Le Nhu Ngoc — Built with Android Studio"
            android:textSize="15sp"
            android:textColor="@color/text_muted"
            android:layout_marginBottom="24dp"/>
    </LinearLayout>
</ScrollView>